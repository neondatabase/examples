# Neon Auth (same project as the function). NEON_AUTH_BASE_URL comes from the
# function's `neonctl env pull`; generate the cookie secret with:
#   openssl rand -base64 32
NEON_AUTH_BASE_URL="https://...neonauth...aws.neon.tech/neondb/auth"
NEON_AUTH_COOKIE_SECRET="generate-with-openssl-rand-base64-32"

# Postgres connection (history is read here). Same DATABASE_URL as the function.
DATABASE_URL="postgresql://neondb_owner:...@ep-...us-east-2.aws.neon.tech/neondb?sslmode=require"

# The deployed chat function's WebSocket URL (its invocation URL with wss://).
NEXT_PUBLIC_CHAT_WS_URL="wss://<branch>-chat.compute.c-1.us-east-2.aws.neon.build"

# All of these are injected by `neon dev` and written by `neon env pull`
# (from the `neon.ts` policy + your linked branch). You normally don't edit them by hand.

NEON_BRANCH="main"

# Postgres (always present) — Mastra stores threads, messages, and per-user
# working memory here via @mastra/pg's PostgresStore.
DATABASE_URL="postgresql://neondb_owner:...@ep-...-pooler.c-3.us-east-2.aws.neon.tech/neondb?channel_binding=require&sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://neondb_owner:...@ep-....c-3.us-east-2.aws.neon.tech/neondb?channel_binding=require&sslmode=require"

# Neon AI Gateway (preview.aiGateway). OPENAI_* back the AI SDK openai() provider
# that powers the Mastra agent's model; NEON_AI_GATEWAY_* are the bare-host + token
# aliases (the chat-completions/MLflow dialect is derived from the base URL).
OPENAI_API_KEY="nt_live_..."
OPENAI_BASE_URL="https://<branch-id>-api.ai.c-3.us-east-2.aws.neon.tech/ai-gateway/openai/v1"
NEON_AI_GATEWAY_TOKEN="nt_live_..."
NEON_AI_GATEWAY_BASE_URL="https://<branch-id>-api.ai.c-3.us-east-2.aws.neon.tech"

# All of these are injected by `neon dev` and written by `neon env pull`
# (from the `neon.ts` policy + your linked branch). You normally don't edit them by hand.

# Postgres (always present) — Mastra stores threads, messages, and per-user
# working memory here via @mastra/pg's PostgresStore.
DATABASE_URL="postgresql://neondb_owner:...@ep-...aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://neondb_owner:...@ep-...aws.neon.tech/neondb?sslmode=require"

# Neon AI Gateway (preview.aiGateway) — read by the AI SDK's openai() provider that
# backs the Mastra agent's model.
OPENAI_API_KEY="nt_live_..."
OPENAI_BASE_URL="https://<branch-id>-api.ai.<region>.aws.neon.tech/ai-gateway/openai/v1"

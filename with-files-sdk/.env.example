# Written by `neon deploy` / `neon env pull` from the `neon.ts` policy + your
# linked branch. The neon adapter (and the AWS SDK) read these automatically —
# you normally don't edit them by hand.

NEON_BRANCH="main"

# Postgres (always present)
DATABASE_URL="postgresql://neondb_owner:...@ep-...-pooler.c-3.us-east-2.aws.neon.tech/neondb?channel_binding=require&sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://neondb_owner:...@ep-....c-3.us-east-2.aws.neon.tech/neondb?channel_binding=require&sslmode=require"

# Neon object storage (preview.buckets)
AWS_ACCESS_KEY_ID="nak_live_..."
AWS_SECRET_ACCESS_KEY="nsk_live_..."
AWS_ENDPOINT_URL_S3="https://<branch-id>.storage.c-3.us-east-2.aws.neon.tech"
AWS_REGION="us-east-2"
